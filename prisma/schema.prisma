generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
}

enum Status {
  HEALTHY
  SICK
  PREGNANT
  SOLD
  DECEASED
}

model Cattle {
  id          String   @id @default(cuid())
  tagNumber   String   @unique
  breed       String
  gender      Gender
  dateOfBirth DateTime
  status      Status

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
